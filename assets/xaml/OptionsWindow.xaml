<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="$(T 'OptSettingsTitle' 'Configuración — SysOpt')" Width="680" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="$(Get-TC 'BgDeep' '#0D0F1A')" WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <!-- ══ Win11 Toggle Switch Style ══ -->
        <Style x:Key="Win11Toggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="50" Height="26">
                            <Border x:Name="trackBorder" CornerRadius="13"
                                    Background="Transparent"
                                    BorderBrush="$(Get-TC 'TextMuted' '#6B7494')"
                                    BorderThickness="2"/>
                            <Border x:Name="thumbOff" Width="16" Height="16" CornerRadius="8"
                                    Background="$(Get-TC 'TextMuted' '#6B7494')"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="5,0,0,0"/>
                            <Border x:Name="thumbOn" Width="18" Height="18" CornerRadius="9"
                                    Background="$(Get-TC 'BtnPrimaryFg' '#FFFFFF')"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,4,0" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="trackBorder" Property="Background"
                                        Value="$(Get-TC 'AccentBlue' '#5BA3FF')"/>
                                <Setter TargetName="trackBorder" Property="BorderBrush"
                                        Value="$(Get-TC 'AccentBlue' '#5BA3FF')"/>
                                <Setter TargetName="thumbOff" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="thumbOn"  Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="trackBorder" Property="Opacity" Value="0.80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Rounded Button Style ══ -->
        <Style x:Key="RoundedBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="$(Get-TC 'ComboHover' '#1A2A4A')"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background decorations -->
        <Rectangle x:Name="optBgRect" Fill="$(Get-TC 'BgDeep' '#0D0F1A')"/>
        <Ellipse Width="300" Height="300" Opacity="0.06"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,-60,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="$(Get-TC 'AccentPurple' '#A47CFF')" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════ LEFT SIDEBAR ═══════════ -->
            <Border x:Name="borderSidebar" Grid.Column="0"
                    Background="$(Get-TC 'BgCard' '#161925')"
                    Padding="12,20,12,20">
                <DockPanel LastChildFill="False">
                    <!-- Title -->
                    <TextBlock DockPanel.Dock="Top" x:Name="txtOptHeader"
                               FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                               Foreground="$(Get-TC 'TextPrimary' '#E8EAF6')"
                               Margin="8,0,0,24">
                        <Run Text="⚙  "/><Run x:Name="runOptTitle" Text="$(T 'OptSettingsTitle' 'Configuración')"/>
                    </TextBlock>

                    <!-- Nav: Interface -->
                    <Border DockPanel.Dock="Top" x:Name="btnNavInterface"
                            Background="$(Get-TC 'ComboSelected' '#1E3060')"
                            CornerRadius="8" Cursor="Hand"
                            Padding="12,10,12,10" Margin="0,0,0,4">
                        <TextBlock x:Name="txtNavInterface"
                                   FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="$(Get-TC 'AccentBlue' '#5BA3FF')">
                            <Run Text="🎨  "/><Run x:Name="runNavInterface" Text="$(T 'OptNavInterface' 'Interfaz')"/>
                        </TextBlock>
                    </Border>

                    <!-- Nav: Behavior -->
                    <Border DockPanel.Dock="Top" x:Name="btnNavBehavior"
                            Background="Transparent"
                            CornerRadius="8" Cursor="Hand"
                            Padding="12,10,12,10" Margin="0,0,0,4">
                        <TextBlock x:Name="txtNavBehavior"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="$(Get-TC 'TextSecondary' '#9BA4C0')">
                            <Run Text="⚡  "/><Run x:Name="runNavBehavior" Text="$(T 'OptNavBehavior' 'Comportamiento')"/>
                        </TextBlock>
                    </Border>

                    <!-- Nav: About -->
                    <Border DockPanel.Dock="Top" x:Name="btnNavAbout"
                            Background="Transparent"
                            CornerRadius="8" Cursor="Hand"
                            Padding="12,10,12,10" Margin="0,0,0,4">
                        <TextBlock x:Name="txtNavAbout"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="$(Get-TC 'TextSecondary' '#9BA4C0')">
                            <Run Text="ℹ  "/><Run x:Name="runNavAbout" Text="$(T 'OptNavAbout' 'Acerca de')"/>
                        </TextBlock>
                    </Border>

                    <!-- Version footer -->
                    <TextBlock DockPanel.Dock="Bottom" x:Name="txtOptVersion"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="$(Get-TC 'TextMuted' '#6B7494')"
                               Margin="8,0,0,0"
                               Text="SysOpt v$($script:AppVersion)"/>
                </DockPanel>
            </Border>

            <!-- ═══════════ RIGHT CONTENT ═══════════ -->
            <Grid Grid.Column="1" Margin="24,20,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── PAGE: Interface ─────────────────────────────────── -->
                <StackPanel x:Name="pageInterface" Grid.Row="0" Visibility="Visible">

                    <!-- Section header: Theme -->
                    <TextBlock x:Name="txtThemeSection"
                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                               Foreground="$(Get-TC 'TextMuted' '#6B7494')"
                               Margin="4,0,0,8"
                               Text="$(T 'OptSectionTheme' 'TEMA VISUAL')"/>
                    <Border x:Name="cardTheme"
                            Background="$(Get-TC 'BgCard' '#161925')"
                            CornerRadius="8" Padding="16,14,16,14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="txtThemeLabel"
                                       FontFamily="Segoe UI" FontSize="13"
                                       Foreground="$(Get-TC 'TextPrimary' '#E8EAF6')"
                                       Margin="0,0,0,8"
                                       Text="$(T 'OptionsThemeLabel' 'Tema visual')"/>
                            <ComboBox x:Name="cmbTheme" Height="32"/>
                        </StackPanel>
                    </Border>

                    <!-- Section header: Language -->
                    <TextBlock x:Name="txtLangSection"
                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                               Foreground="$(Get-TC 'TextMuted' '#6B7494')"
                               Margin="4,0,0,8"
                               Text="$(T 'OptSectionLang' 'IDIOMA')"/>
                    <Border x:Name="cardLang"
                            Background="$(Get-TC 'BgCard' '#161925')"
                            CornerRadius="8" Padding="16,14,16,14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="txtLangLabel"
                                       FontFamily="Segoe UI" FontSize="13"
                                       Foreground="$(Get-TC 'TextPrimary' '#E8EAF6')"
                                       Margin="0,0,0,8"
                                       Text="$(T 'OptionsLangLabel' 'Idioma')"/>
                            <ComboBox x:Name="cmbLang" Height="32"/>
                        </StackPanel>
                    </Border>

                    <!-- Hint -->
                    <TextBlock x:Name="txtOptHint"
                               FontFamily="Segoe UI" FontSize="11" FontStyle="Italic"
                               Foreground="$(Get-TC 'TextMuted' '#6B7494')"
                               Margin="4,0,0,0" TextWrapping="Wrap"
                               Text="$(T 'OptRestartHint' 'Algunos cambios de idioma requieren reiniciar SysOpt.')"/>
                </StackPanel>

                <!-- ── PAGE: Behavior ──────────────────────────────────── -->
                <StackPanel x:Name="pageBehavior" Grid.Row="0" Visibility="Collapsed">

                    <!-- Section: Toast -->
                    <TextBlock x:Name="txtToastSection"
                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                               Foreground="$(Get-TC 'TextMuted' '#6B7494')"
                               Margin="4,0,0,8"
                               Text="$(T 'OptSectionToast' 'NOTIFICACIONES')"/>
                    <Border x:Name="cardToast"
                            Background="$(Get-TC 'BgCard' '#161925')"
                            CornerRadius="8" Padding="16,14,16,14" Margin="0,0,0,16">
                        <DockPanel>
                            <ToggleButton x:Name="tglToast" DockPanel.Dock="Right"
                                          Style="{StaticResource Win11Toggle}"
                                          VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock x:Name="txtToastLabel"
                                           FontFamily="Segoe UI" FontSize="13"
                                           Foreground="$(Get-TC 'TextPrimary' '#E8EAF6')"
                                           Text="$(T 'OptToggleToast' 'Notificaciones toast')"/>
                                <TextBlock x:Name="txtToastDesc"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="$(Get-TC 'TextSecondary' '#9BA4C0')"
                                           Margin="0,2,0,0" TextWrapping="Wrap"
                                           Text="$(T 'OptToggleToastDesc' 'Mostrar alertas emergentes al completar tareas')"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Toast test button -->
                    <Border x:Name="cardToastTest"
                            Background="$(Get-TC 'BgCard' '#161925')"
                            CornerRadius="8" Padding="16,14,16,14" Margin="0,0,0,16">
                        <DockPanel>
                            <Button x:Name="btnToastTest" DockPanel.Dock="Right"
                                    Content="🔔 Test" Width="90" Height="32"
                                    Style="{StaticResource RoundedBtn}"
                                    Background="$(Get-TC 'BtnSecondaryBg' '#1E2235')"
                                    BorderBrush="$(Get-TC 'AccentBlue' '#5BA3FF')"
                                    BorderThickness="1"
                                    Foreground="$(Get-TC 'AccentBlue' '#5BA3FF')"
                                    VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock x:Name="txtToastTestLabel"
                                           FontFamily="Segoe UI" FontSize="13"
                                           Foreground="$(Get-TC 'TextPrimary' '#E8EAF6')"
                                           Text="$(T 'OptToastTest' 'Probar notificación')"/>
                                <TextBlock x:Name="txtToastTestDesc"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="$(Get-TC 'TextSecondary' '#9BA4C0')"
                                           Margin="0,2,0,0"
                                           Text="$(T 'OptToastTestDesc' 'Enviar una notificación toast de prueba')"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Section: Debug -->
                    <TextBlock x:Name="txtDebugSection"
                               FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                               Foreground="$(Get-TC 'TextMuted' '#6B7494')"
                               Margin="4,0,0,8"
                               Text="$(T 'OptSectionDebug' 'DEPURACIÓN')"/>
                    <Border x:Name="cardDebug"
                            Background="$(Get-TC 'BgCard' '#161925')"
                            CornerRadius="8" Padding="16,14,16,14" Margin="0,0,0,16">
                        <DockPanel>
                            <ToggleButton x:Name="tglDebugLog" DockPanel.Dock="Right"
                                          Style="{StaticResource Win11Toggle}"
                                          VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock x:Name="txtDebugLabel"
                                           FontFamily="Segoe UI" FontSize="13"
                                           Foreground="$(Get-TC 'TextPrimary' '#E8EAF6')"
                                           Text="$(T 'OptToggleDebug' 'Logs de depuración')"/>
                                <TextBlock x:Name="txtDebugDesc"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="$(Get-TC 'TextSecondary' '#9BA4C0')"
                                           Margin="0,2,0,0" TextWrapping="Wrap"
                                           Text="$(T 'OptToggleDebugDesc' 'Registrar información detallada en la consola (nivel DBG)')"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- ── PAGE: About (winver-style) ──────────────────────── -->
                <StackPanel x:Name="pageAbout" Grid.Row="0" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">

                    <!-- Logo -->
                    <Image x:Name="aboutLogoOpt" Width="80" Height="80"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- SysOpt title -->
                    <TextBlock HorizontalAlignment="Center" FontFamily="Segoe UI"
                               FontSize="28" FontWeight="Bold" Margin="0,0,0,2">
                        <Run Foreground="$(Get-TC 'TextPrimary' '#E8EAF6')" Text="SYS"/><Run Foreground="$(Get-TC 'AccentBlue' '#5BA3FF')" Text="OPT"/>
                    </TextBlock>

                    <!-- Subtitle -->
                    <TextBlock x:Name="txtAboutSubtitle" HorizontalAlignment="Center"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="$(Get-TC 'TextMuted' '#6B7494')" Margin="0,0,0,14"
                               Text="Windows Optimizer GUI"/>

                    <!-- Version badge -->
                    <Border CornerRadius="6" Background="#1A5BA3FF" BorderBrush="#405BA3FF"
                            BorderThickness="1" Padding="14,6" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="$(Get-TC 'AccentBlue' '#5BA3FF')"
                                   Text="v$($script:AppVersion)"/>
                    </Border>

                    <!-- Separator -->
                    <Rectangle Height="1" Fill="$(Get-TC 'BorderSubtle' '#252B40')"
                               Width="280" Margin="0,0,0,20"/>

                    <!-- Developer -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <TextBlock x:Name="txtAboutDeveloper" FontFamily="Segoe UI" FontSize="12"
                                   Foreground="$(Get-TC 'TextSecondary' '#9BA4C0')">
                            <Run Text="$(T 'AboutDeveloper' 'Desarrollado por') "/></TextBlock>
                        <TextBlock FontFamily="Segoe UI" FontSize="12">
                            <Hyperlink x:Name="lnkGithubOpt" NavigateUri="https://github.com/Danewmalavita/"
                                       Foreground="$(Get-TC 'AccentBlue' '#5BA3FF')" TextDecorations="None">Danew Malavita</Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <!-- Copyright -->
                    <TextBlock x:Name="txtAboutCopyright" HorizontalAlignment="Center"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="$(Get-TC 'TextMuted' '#6B7494')" Margin="0,0,0,28"
                               Text="© 2026 Danew Malavita"/>

                    <!-- Changelog button -->
                    <Button x:Name="btnChangelog" Width="220" Height="36"
                            HorizontalAlignment="Center"
                            Style="{StaticResource RoundedBtn}"
                            Background="$(Get-TC 'BtnSecondaryBg' '#1E2235')"
                            BorderBrush="$(Get-TC 'AccentBlue' '#5BA3FF')"
                            BorderThickness="1"
                            Foreground="$(Get-TC 'AccentBlue' '#5BA3FF')"
                            Content="📋  $(T 'AboutBtnChangelog' 'Cambios en la versión')"/>
                </StackPanel>

                <!-- ── BUTTONS (always visible) ─────────────────────── -->
                <StackPanel x:Name="buttonsPanel" Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button x:Name="btnOptApply" Content="$(T 'OptionsBtnApply' 'Aplicar')"
                            Width="110" Height="34" Margin="0,0,10,0"
                            Style="{StaticResource RoundedBtn}"
                            Background="$(Get-TC 'BtnSecondaryBg' '#1E2235')"
                            BorderBrush="$(Get-TC 'AccentBlue' '#5BA3FF')"
                            BorderThickness="1"
                            Foreground="$(Get-TC 'AccentBlue' '#5BA3FF')"/>
                    <Button x:Name="btnOptClose" Content="$(T 'OptionsBtnClose' 'Cerrar')"
                            Width="110" Height="34"
                            Style="{StaticResource RoundedBtn}"
                            Background="$(Get-TC 'HdrBtnBg' '#1E2235')"
                            BorderBrush="$(Get-TC 'HdrBtnBorder' '#2A2F48')"
                            BorderThickness="1"
                            Foreground="$(Get-TC 'TextSecondary' '#9BA4C0')"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>